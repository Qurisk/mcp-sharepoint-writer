# Clé API MCP (chaîne aléatoire, à générer avec : openssl rand -hex 32)
MCP_API_KEY=your_random_api_key_here

# Azure App Registration (Entra ID)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# SharePoint
# SHAREPOINT_SITE_ID : récupérer via GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{site-path}
SHAREPOINT_SITE_ID=your-site-id

# SHAREPOINT_DRIVE_ID : récupérer via GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
SHAREPOINT_DRIVE_ID=your-drive-id
